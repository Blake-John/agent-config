{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "ctx7"]
    },
    "mcp-deepwiki": {
      "type": "local",
      "command": ["npx", "-y", "mcp-deepwiki@latest"]
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "-y", "fetch-mcp"]
    },
    "paper_search_mcp": {
      "type": "local",
      "command": ["python", "-m", "paper_search_mcp.server"]
    },
    "bing-cn": {
      "type": "local",
      "command": ["npx", "-y", "bing-cn-mcp"]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "lark-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@larksuiteoapi/lark-mcp", "mcp"]
    },
    "mineru-mcp": {
      "type": "local",
      "command": ["mineru-mcp"]
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"]
    }
  }
}
