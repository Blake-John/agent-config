{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llamacpp",
      "options": {
        "baseURL": "http://127.0.0.1:8001/v1"
      },
      "models": {
        "Qwen3.5-4B-GGUF": {
          "name": "unsloth/Qwen3.5-4B-GGUF"
        },
        "Qwen3.5-2B-GGUF": {
          "name": "unsloth/Qwen3.5-2B-GGUF"
        }
      }
    }
  },
  "mcp": {
    "mcp-deepwiki": {
      "type": "local",
      "command": ["npx", "-y", "mcp-deepwiki@latest"]
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "-y", "fetch-mcp"]
    },
    "paper_search_mcp": {
      "type": "local",
      "command": ["python", "-m", "paper_search_mcp.server"]
    },
    "bing-cn": {
      "type": "local",
      "command": ["npx", "-y", "bing-cn-mcp"]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "lark-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@larksuiteoapi/lark-mcp", "mcp"]
    },
    "mineru-mcp": {
      "type": "local",
      "command": ["mineru-mcp"]
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"]
    }
  },
  "default_agent": "build",
  "instructions": [
      "AGENTS.md",
      "INSTRUCTIONS.md",
      "~/.config/opencode/instructions/INSTRUCTIONS.md",
      "~/.config/opencode/instructions/GENERAL-PRINCIPLE.md",
      "~/.config/opencode/instructions/DEVWORKFLOW.md",
      "~/.config/opencode/instructions/CODING-STYLE.md"
  ],
}
